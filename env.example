# Example environment configuration for community-climate-justice-archive
# Copy this file to .env and update with your actual values

# NocoDB Configuration
NOCODB_ENDPOINT=https://your-nocodb-instance.com
NOCODB_API_KEY=your_api_key_here
NOCODB_TABLE_ID=your_table_id_here

# Data Source Selection
# Set to "true" to use NocoDB API, "false" to use SQLite
USE_NOCODB=false
